## Example environment variables for RAGPipeline
## Copy this file to `.env` and fill in real values locally.

# Provider keys (only set the ones you need)
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
GROQ_API_KEY=

# Model / embedding settings
OPENAI_MODEL=gpt-3.5-turbo
EMBED_BACKEND=hf
HF_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# App behaviour / feature flags
LOG_LEVEL=DEBUG
LOG_TO_FILE=0
LOG_DIR=logs
LOG_DAILY=0
LOG_BASE=app
LOG_FILE=app.log
LOG_MAX_BYTES=1048576
LOG_BACKUPS=5

DISABLE_PERSIST=0
SKIP_ISSUE_EMBED=1
INCREMENTAL_ADD=1
SMALL_CORPUS_THRESHOLD=400

# Loader / chunking
CHUNK_SIZE=1500
CHUNK_OVERLAP=150
TOP_K=8

# Diagnostics / testing
TRACE_RUN=0
METRICS_LOG=1
DIAG_ENABLE=1
DIAG_ISSUE_SAMPLE=50
DIAG_CONTEXT_SAMPLE=20

# Optional: external prefilter settings
PREFILTER_ERRORS=1
PREFILTER_WINDOW=2

# Note: Do NOT commit your local `.env` with real secrets.
